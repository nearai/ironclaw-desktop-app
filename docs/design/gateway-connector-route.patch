+fn lifecycle_package_ref_for_extension(
+    extension_name: &ExtensionName,
+) -> Result<LifecyclePackageRef, RebornServicesError> {
+    let package_id = match extension_name.as_str() {
+        "google_calendar" => "google-calendar",
+        other => other,
+    };
+    LifecyclePackageRef::new(LifecyclePackageKind::Extension, package_id)
+        .map_err(map_lifecycle_error)
+}
+
+fn setup_action(
+    package_ref: LifecyclePackageRef,
+    request: WebUiSetupExtensionRequest,
+) -> Result<Option<LifecycleProductAction>, RebornServicesError> {
+    let Some(action) = request
+        .action
+        .as_deref()
+        .map(str::trim)
+        .filter(|action| !action.is_empty())
+    else {
+        return Ok(None);
+    };
+    let normalized = action.replace('-', "_").to_ascii_lowercase();
+    match normalized.as_str() {
+        "begin" | "setup" | "project" | "status" | "readiness" => Ok(None),
+        "install" | "extension_install" => Ok(Some(LifecycleProductAction::ExtensionInstall {
+            package_ref,
+        })),
+        "activate" | "extension_activate" => Ok(Some(LifecycleProductAction::ExtensionActivate {
+            package_ref,
+        })),
+        "auth" | "authorize" | "connect" | "extension_auth" => {
+            Ok(Some(LifecycleProductAction::ExtensionAuth { package_ref }))
+        }
+        "configure" | "config" | "extension_configure" => {
+            Ok(Some(LifecycleProductAction::ExtensionConfigure {
+                package_ref,
+                payload: request.payload,
+            }))
+        }
+        "remove" | "uninstall" | "extension_remove" => {
+            Ok(Some(LifecycleProductAction::ExtensionRemove {
+                package_ref,
+            }))
+        }
+        other => Err(map_lifecycle_error(
+            ProductWorkflowError::UnsupportedActionKind {
+                kind: other.to_string(),
+            },
+        )),
+    }
+}
