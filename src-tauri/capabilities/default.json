{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for IronClaw desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:app:default",
    "updater:default",
    "dialog:default",
    "notification:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "binaries/ironclaw", "sidecar": true, "args": true }
      ]
    },
    {
      "identifier": "shell:allow-kill",
      "allow": [
        { "name": "binaries/ironclaw", "sidecar": true, "args": true }
      ]
    },
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "https://**" },
        { "url": "http://127.0.0.1:*/" },
        { "url": "http://localhost:*/" }
      ]
    }
  ]
}
