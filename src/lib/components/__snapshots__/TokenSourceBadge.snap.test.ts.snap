// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`TokenSourceBadge snapshots > matches the absent snapshot 1`] = `"<!----><span data-testid="token-source-badge" class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-[10px] font-medium border bg-text-muted/10 text-text-muted border-text-muted/30" title="No gateway token saved. Enter one in the profile section above to sign in." aria-label="Token source: No token" data-source="absent"><span aria-hidden="true" class="w-1.5 h-1.5 rounded-full bg-text-muted/50"></span> No token</span>"`;

exports[`TokenSourceBadge snapshots > matches the file fallback (degraded) snapshot 1`] = `"<!----><span data-testid="token-source-badge" class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-[10px] font-medium border bg-accent-gold/10 text-accent-gold border-accent-gold/30" title="Token loaded from app_data_dir/tokens/. The keychain ACL prompt likely hung; signed Developer-ID builds avoid this path." aria-label="Token source: File fallback" data-source="file"><span aria-hidden="true" class="w-1.5 h-1.5 rounded-full bg-accent-gold"></span> File fallback</span>"`;

exports[`TokenSourceBadge snapshots > matches the keychain (normal) snapshot 1`] = `"<!----><span data-testid="token-source-badge" class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-[10px] font-medium border bg-accent-cyan/10 text-accent-cyan border-accent-cyan/30" title="Token loaded from macOS Keychain (normal path)." aria-label="Token source: Keychain" data-source="keychain"><span aria-hidden="true" class="w-1.5 h-1.5 rounded-full bg-accent-cyan"></span> Keychain</span>"`;
