exports[`Toasts snapshots > matches the success-kind snapshot 1`] = `"<div class="fixed top-4 right-4 z-50 flex flex-col gap-2 pointer-events-none"><div role="status" class="pointer-events-auto bg-bg-surface border rounded-md px-4 py-2.5 text-xs shadow-lg min-w-[220px] max-w-[360px] flex items-center gap-3 border-positive/60 text-positive"><span class="flex-1 leading-relaxed">success toast</span> <button type="button" class="text-text-muted hover:text-text-primary transition-colors" aria-label="Dismiss"><svg viewBox="0 0 24 24" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button></div></div>"`;
