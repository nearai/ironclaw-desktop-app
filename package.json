{
  "name": "ironclaw-desktop",
  "version": "0.4.158",
  "private": true,
  "type": "module",
  "scripts": {
    "build:reborn-sidecars": "bash scripts/build-reborn-sidecars.sh",
    "build:updater-manifest": "node scripts/build-updater-manifest.mjs",
    "check:release-readiness": "bash scripts/check-release-readiness.sh",
    "check:static-bundle": "node scripts/check-static-bundle-size.mjs",
    "lint:static-copy": "node scripts/lint-static-copy.mjs",
    "lint:static-tokens": "node scripts/lint-static-status-tokens.mjs",
    "test:scripts": "node --test scripts/*.test.mjs",
    "test:static": "find crates/ironclaw_webui_v2_static/static/js -name '*.test.mjs' -print0 | xargs -0 node --test",
    "test:e2e": "npm run smoke:webui-static",
    "test:design-static": "node scripts/design-test-harness.mjs",
    "test:a11y-static": "playwright test --config playwright.static.config.ts",
    "smoke:gate-enforcement": "node scripts/smoke-gate-enforcement.mjs",
    "smoke:packaged": "bash scripts/smoke-packaged-app.sh",
    "smoke:webui-static": "node scripts/smoke-webui-static.mjs",
    "verify:static-frontend": "node scripts/verify-static-frontend-contract.mjs",
    "prepare:universal-sidecars": "bash scripts/prepare-universal-sidecars.sh",
    "prepare:webui-static": "node scripts/prepare-webui-static.mjs",
    "dev:webui-static": "node scripts/serve-webui-static.mjs",
    "tauri": "node scripts/tauri-cli.mjs",
    "format": "prettier --write \"crates/ironclaw_webui_v2_static/static/js/**/*.js\" \"scripts/**/*.mjs\"",
    "prepare": "simple-git-hooks || true"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "pre-push": "npm run verify:static-frontend && npm run check:static-bundle && npm run lint:static-tokens && npm run lint:static-copy && npm run test:design-static && npm run smoke:webui-static && npm run smoke:gate-enforcement && npm run test:a11y-static && npm run test:static && npm run test:scripts"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "prettier --check"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2.2.7",
    "@types/node": "^25.9.1",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.25.12",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "pdfjs-dist": "^4.10.38",
    "postcss": "^8.5.1",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^3.4.17",
    "tesseract.js": "^7.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@tailwindcss/browser": "^4.1.17",
    "@tanstack/react-query": "^5.87.4",
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2",
    "@types/dompurify": "^3.0.5",
    "dompurify": "^3.4.7",
    "highlight.js": "^11.11.1",
    "htm": "^3.1.1",
    "katex": "^0.16.22",
    "marked": "^17.0.2",
    "mermaid": "^11.11.0",
    "plotly.js-dist-min": "^3.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.62.0",
    "react-router": "^7.9.6"
  }
}
